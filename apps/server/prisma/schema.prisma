generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  walletAddress  String?        @unique
  authNonce      String?
  username       String         @unique
  passwordHash   String?
  displayName    String
  hasDisplayName Boolean        @default(false)
  createdAt      DateTime       @default(now())
  profile      PlayerProfile?
  bulls        Bull[]
  items        Item[]
  raceEntries  RaceEntry[]
  bets         Bet[]
  listings     MarketListing[] @relation("SellerListings")
  purchases    MarketListing[] @relation("BuyerListings")
  pastures     PasturePlot[]
}

model PlayerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gold        Float    @default(0)
  hay         Int      @default(0)
  ore         Int      @default(0)
  wood        Int      @default(0)
  stableLevel Int      @default(1)
  stableWood  Int      @default(0)
  posX        Float    @default(28)
  posY        Float    @default(25)
  lastWheelSpinAt DateTime?
  helpSeen    Boolean  @default(false)
  betAmount   Int      @default(50)
  forgeOre    Int      @default(100)
  listHay     Int      @default(5)
  listOre     Int      @default(8)
  listWood    Int      @default(5)
  breedSel    Int[]    @default([])
  followingBullIds Int[] @default([])
  breedingAId Int?
  breedingBId Int?
  breedingDone DateTime?
  nextBullId  Int      @default(2)
  nextItemId  Int      @default(1)
}

model Bull {
  id        Int      @id @default(autoincrement())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  level     Int      @default(1)
  xp        Float    @default(0)
  speed     Int
  stamina   Int
  accel     Int
  temper    Int
  energy    Float    @default(100)
  coat      String
  trait     String   @default("normal")
  rarity    String   @default("common")
  location  String   @default("stable")
  denPlotId Int?
  items     Item[]
  entries   RaceEntry[] @relation("BullEntries")
}

model Item {
  id          Int     @id @default(autoincrement())
  ownerId     String
  owner       User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  kind        String  @default("bull")
  equippedChar Boolean @default(false)
  slot        String
  rarity      String
  rarityColor String
  name        String
  color       String
  bonusStat   String?
  bonusAmt    Int?
  equippedTo  Int?
  bull        Bull?   @relation(fields: [equippedTo], references: [id])
}

model WorldNode {
  id        String    @id
  type      String
  mat       String
  x         Float
  y         Float
  deadUntil DateTime?
}

model Race {
  id        String      @id @default(cuid())
  status    String      @default("scheduled")
  startAt   DateTime
  endAt     DateTime?
  field     Json
  simulatedField Json?
  results   Json?
  entries   RaceEntry[]
  bets      Bet[]
  createdAt DateTime    @default(now())
}

model RaceEntry {
  id       String  @id @default(cuid())
  raceId   String
  race     Race    @relation(fields: [raceId], references: [id], onDelete: Cascade)
  userId   String?
  user     User?   @relation(fields: [userId], references: [id])
  bullId   Int?
  bull     Bull?   @relation("BullEntries", fields: [bullId], references: [id])
  isNpc    Boolean @default(false)
  npcData  Json?
  bullData Json?
}

model Bet {
  id           String @id @default(cuid())
  raceId       String
  race         Race   @relation(fields: [raceId], references: [id], onDelete: Cascade)
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetBullId String
  targetName   String
  amount       Int
  odds         Float
  payout       Int?
  won          Boolean?
}

model MarketListing {
  id            String    @id @default(cuid())
  sellerId      String
  seller        User      @relation("SellerListings", fields: [sellerId], references: [id], onDelete: Cascade)
  buyerId       String?
  buyer         User?     @relation("BuyerListings", fields: [buyerId], references: [id])
  reservedById  String?
  type          String
  mat           String?
  qty           Int?
  itemData      Json?
  bullData      Json?
  price         Int
  tokenPrice    Decimal?  @db.Decimal(20, 6)
  status        String    @default("open")
  reservedUntil DateTime?
  cooldownUntil DateTime?
  txSignature   String?   @unique
  createdAt     DateTime  @default(now())
  soldAt        DateTime?
  cancelledAt   DateTime?
}

model PasturePlot {
  id           Int       @id
  ownerId      String?
  owner        User?     @relation(fields: [ownerId], references: [id])
  level        Int       @default(1)
  woodInvested Int       @default(0)
  nextSpawnAt  DateTime?
  displayBull  Json?
}
